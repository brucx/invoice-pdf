{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "invoice-pdf",
  "compatibility_date": "2026-07-08",
  "routes": [
    { "pattern": "invoices-generator.net", "custom_domain": true },
    { "pattern": "www.invoices-generator.net", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
